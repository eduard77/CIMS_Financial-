{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/financials-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithEnvironmentName", "WithThreadId" ],
    "Properties": {
      "Application": "Financials.Web"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "FinancialsDb": "Server=(localdb)\\MSSQLLocalDB;Database=Financials;Trusted_Connection=True;Encrypt=False;MultipleActiveResultSets=True"
  },
  "Cims": {
    "BaseAddress": "https://cims.genera-systems.com/",
    "CacheTtl": "00:01:00",
    "TotalTimeout": "00:00:30",
    "RetryCount": 3,
    "Auth": {
      "Authority": "https://auth.genera-systems.com",
      "Audience": "financials"
    }
  }
}
